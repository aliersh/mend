# Privy app id — public by design, safe in client bundle.
VITE_PRIVY_APP_ID=

# Optional: Pimlico sponsorship policy id (sp_...). Not a secret.
# Leave empty unless Pimlico requires an explicit policy to sponsor. The
# bundler/paymaster URLs (and the Pimlico API key) live in the Privy dashboard,
# never here.
VITE_PIMLICO_SPONSORSHIP_POLICY_ID=

# Optional: override the reads RPC (e.g. your own Alchemy/Infura Base Sepolia URL).
# Leave empty to use the built-in default. The endpoint must allow ~10k-block
# getLogs ranges — the chain's canonical public RPC does not, which is why a
# capable default is shipped. Lower LOG_WINDOW in src/lib/client.ts if a custom
# RPC rejects the range.
VITE_RPC_URL=
