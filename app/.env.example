# Privy app id — public by design, safe in client bundle.
VITE_PRIVY_APP_ID=

# Optional: Pimlico sponsorship policy id (sp_...). Not a secret.
# Leave empty unless Pimlico requires an explicit policy to sponsor. The
# bundler/paymaster URLs (and the Pimlico API key) live in the Privy dashboard,
# never here.
VITE_PIMLICO_SPONSORSHIP_POLICY_ID=
